# ─────────────────────────────────────────────────────────────────────────────
# TurboRAG Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Hostname or IP of the PostgreSQL server
POSTGRES_HOST=localhost

# Port the PostgreSQL server listens on
POSTGRES_PORT=5432

# Name of the database to connect to
POSTGRES_DB=turborag

# Database user with read/write permissions to POSTGRES_DB
POSTGRES_USER=tsuser

# Password for the database user
POSTGRES_PASSWORD=changeme

# Number of connections to keep in the async connection pool
POSTGRES_POOL_SIZE=5

# ── Neo4j (optional) ──────────────────────────────────────────────────────────
# Enable Neo4j by starting Docker with: docker compose --profile graph up
# Leave these blank if you are not using graph-augmented retrieval.

# Bolt connection URI (e.g. bolt://localhost:7687 or neo4j+s://xxx.databases.neo4j.io)
NEO4J_URI=bolt://localhost:7687

# Neo4j username
NEO4J_USER=neo4j

# Neo4j password (must be changed from the default on first run)
NEO4J_PASSWORD=changeme_neo4j

# Name of the Neo4j database to use (default: neo4j)
NEO4J_DATABASE=neo4j

# ── Index defaults ────────────────────────────────────────────────────────────
# Bit-width used for vector quantisation (1, 2, 4, or 8)
DEFAULT_BIT_WIDTH=4

# Default number of results returned by a search query
DEFAULT_TOP_K=10
